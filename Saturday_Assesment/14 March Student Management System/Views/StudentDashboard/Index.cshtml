@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-4">
    <h2>Student Dashboard</h2>
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">My Profile</h5>
                    <p class="card-text">View and update profile and course details.</p>
                    <a asp-controller="StudentDashboard" asp-action="Profile" class="btn btn-primary w-100">View Profile</a>
                </div>
            </div>
        </div>
    </div>
</div>
