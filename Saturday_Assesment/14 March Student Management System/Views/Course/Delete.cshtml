@model StudentManagementSys.Models.Course

<h2>Delete Course</h2>

<h3>Are you sure you want to delete this course?</h3>
<div>
    <dl class="row mt-4">
        <dt class="col-sm-2">Course Name</dt>
        <dd class="col-sm-10">@Model.CourseName</dd>
        
        <dt class="col-sm-2">Duration</dt>
        <dd class="col-sm-10">@Model.Duration</dd>

        <dt class="col-sm-2">Fees</dt>
        <dd class="col-sm-10">@Model.Fees</dd>

        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.Department?.DepartmentName</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="CourseId" />
        <input type="submit" value="Delete" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this course?');" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
