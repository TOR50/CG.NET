@model StudentManagementSys.Models.Student

<h2>Delete Student</h2>

<h3>Are you sure you want to delete this student?</h3>
<div>
    <dl class="row mt-4">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.StudentName</dd>
        
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        
        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.Department?.DepartmentName</dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.Course?.CourseName</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="StudentId" />
        <input type="submit" value="Delete" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this student?');" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
