@model IEnumerable<mvc2.Models.StudentModel>

@{
    ViewData["Title"] = "Student List";
}

<h2>Student List</h2>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger" role="alert">
        @ViewBag.ErrorMessage
    </div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Age Squared ($Age^2$)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Name</td>
                <td>@student.Age</td>
                <td>@student.AgeSquared</td>
            </tr>
        }
    </tbody>
</table>
