@model IEnumerable<CollegeApplication.Models.ApplicationForm>

@{
    ViewData["Title"] = "Applications";
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 fade-in">
        <div>
            <h2 style="color: var(--primary); font-weight: 700;">📋 Applications</h2>
            <p class="text-muted mb-0">@Model.Count() total applications</p>
        </div>
        <a asp-action="Create" class="btn btn-modern btn-primary-modern">
            ✨ New Application
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-modern alert-success-modern fade-in mb-4">
            <span style="font-size: 1.5rem;">✅</span>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (Model.Any())
    {
        <div class="table-modern fade-in">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Course</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.ApplicationId</strong></td>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td><span class="badge" style="background: var(--primary);">@item.Course</span></td>
                            <td>@item.ApplicationDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.ApplicationId" class="btn btn-sm btn-modern" style="background:#e0e7ff;color:#4f46e5;">View</a>
                                <a asp-action="IDCard" asp-route-id="@item.ApplicationId" class="btn btn-sm btn-modern" style="background:#d1fae5;color:#065f46;">🪪 ID</a>
                                <a asp-action="Edit" asp-route-id="@item.ApplicationId" class="btn btn-sm btn-modern" style="background:#fef3c7;color:#92400e;">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ApplicationId" class="btn btn-sm btn-modern" style="background:#fee2e2;color:#dc2626;">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card card-modern text-center py-5 fade-in">
            <div class="card-body">
                <div style="font-size: 4rem;">📭</div>
                <h4 class="mt-3">No Applications Yet</h4>
                <p class="text-muted">Start by creating your first application</p>
                <a asp-action="Create" class="btn btn-modern btn-primary-modern mt-2">
                    ✨ Create Application
                </a>
            </div>
        </div>
    }
</div>
