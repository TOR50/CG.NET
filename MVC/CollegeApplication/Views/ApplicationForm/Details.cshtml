@model CollegeApplication.Models.ApplicationForm

@{
    ViewData["Title"] = "Application Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="details-card fade-in">
                <div class="details-header">
                    <h2>🎓 Application #@Model.ApplicationId</h2>
                    <p class="mb-0">Submitted on @Model.ApplicationDate.ToString("dd MMMM yyyy, hh:mm tt")</p>
                </div>

                <div class="details-body">
                    <!-- Personal Information -->
                    <div class="detail-section">
                        <h5 class="detail-section-title">👤 Personal Information</h5>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="detail-label">Full Name</div>
                                <div class="detail-value">@Model.FullName</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Father's Name</div>
                                <div class="detail-value">@Model.FatherName</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Mother's Name</div>
                                <div class="detail-value">@Model.MotherName</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Date of Birth</div>
                                <div class="detail-value">@Model.DateOfBirth.ToString("dd MMMM yyyy")</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Gender</div>
                                <div class="detail-value">@Model.Gender</div>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Information -->
                    <div class="detail-section">
                        <h5 class="detail-section-title">📞 Contact Information</h5>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="detail-label">Email</div>
                                <div class="detail-value">@Model.Email</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Phone</div>
                                <div class="detail-value">@Model.PhoneNumber</div>
                            </div>
                            <div class="detail-item" style="grid-column: 1 / -1;">
                                <div class="detail-label">Address</div>
                                <div class="detail-value">@Model.Address, @Model.City, @Model.State - @Model.Pincode</div>
                            </div>
                        </div>
                    </div>

                    <!-- Academic Information -->
                    <div class="detail-section">
                        <h5 class="detail-section-title">🎓 Academic Information</h5>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="detail-label">Course Applied</div>
                                <div class="detail-value">@Model.Course</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">10th Percentage</div>
                                <div class="detail-value">@Model.TenthPercentage%</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">12th Percentage</div>
                                <div class="detail-value">@Model.TwelfthPercentage%</div>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2 flex-wrap pt-3 border-top">
                        <a asp-action="IDCard" asp-route-id="@Model.ApplicationId" class="btn btn-modern btn-success-modern">
                            🪪 View ID Card
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.ApplicationId" class="btn btn-modern btn-warning-modern">
                            ✏️ Edit
                        </a>
                        <a asp-action="Index" class="btn btn-modern btn-outline-modern">
                            ← Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
